@using solution.ViewModels.Team
@model List<MemberVM>

<div class="d-flex justify-content-between mb-3">
    <h3>Team Members</h3>

    <a asp-action="Create"
       class="btn btn-primary">
        Add Member
    </a>
</div>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>Image</th>
            <th>Name</th>
            <th>Job</th>
            <th>Description</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>
                    <img src="~/uploads/team/@item.Image"
                         width="70"
                         height="70"
                          />
                </td>

                <td>@item.Name</td>

                <td>@item.Job</td>

                <td>@item.Description</td>

                <td>

                    <a asp-action="Detail"
                       asp-route-id="@item.Id"
                       class="btn btn-info btn-sm">
                        Detail
                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@item.Id"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>