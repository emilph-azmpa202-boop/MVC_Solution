@using solution.ViewModels.Team
@model MemberVM

<div class="card border-danger">

    <div class="card-header bg-danger text-white">
        <h4>Delete Member</h4>
    </div>

    <div class="card-body">

        <div class="text-center mb-4">

            <img src="~/uploads/team/@Model.Image"
                 width="150"
                 />

        </div>

        <table class="table table-bordered">

            <tr>
                <th>Name</th>
                <td>@Model.Name</td>
            </tr>

            <tr>
                <th>Job</th>
                <td>@Model.Job</td>
            </tr>

            <tr>
                <th>Description</th>
                <td>@Model.Description</td>
            </tr>

        </table>

        <div class="alert alert-warning">
            Are you sure you want to delete this member?
        </div>

        <form method="post">

            <input type="hidden"
                   name="id"
                   value="@Model.Id" />

            <button type="submit"
                    class="btn btn-danger">
                Delete
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>

</div>