<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Solution Admin</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            min-height: 100vh;
            overflow-x: hidden;
        }

        .sidebar {
            width: 250px;
            min-height: 100vh;
            background: #212529;
        }

            .sidebar .nav-link {
                color: #adb5bd;
                padding: 12px 20px;
            }

                .sidebar .nav-link:hover {
                    background-color: #343a40;
                    color: white;
                }

                .sidebar .nav-link.active {
                    background-color: #0d6efd;
                    color: white;
                }

        .content {
            width: 100%;
            padding: 20px;
        }

        .logo {
            color: white;
            font-size: 24px;
            font-weight: bold;
            text-align: center;
            padding: 20px;
            border-bottom: 1px solid #495057;
        }
    </style>
</head>
<body>

    <div class="d-flex">

        <!-- Sidebar -->
        <div class="sidebar">

            <div class="logo">
                Solution
            </div>

            <ul class="nav flex-column mt-3">

                <li class="nav-item">
                    <a class="nav-link active"
                       asp-controller="home"
                       asp-action="Index">
                        Dashboard
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link"
                       asp-controller="team"
                       asp-action="Index">
                        Team
                    </a>
                </li>

                

            </ul>

        </div>

        <!-- Content -->
        <div class="content">

            <nav class="navbar navbar-light bg-light rounded shadow-sm mb-4">
                <div class="container-fluid">
                    <span class="navbar-brand mb-0 h1">
                        Admin Panel
                    </span>
                </div>
            </nav>

            <main>
                @RenderBody()
            </main>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>