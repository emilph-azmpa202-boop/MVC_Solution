@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid">

    <div class="mb-4">
        <h2 class="fw-bold">Dashboard</h2>
        <p class="text-muted">Welcome to Solution Admin Panel</p>
    </div>

    <div class="row g-4">

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Services</h5>
                    <h2 class="fw-bold text-primary">12</h2>
                    <p class="text-muted mb-0">Total Services</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Team</h5>
                    <h2 class="fw-bold text-success">8</h2>
                    <p class="text-muted mb-0">Team Members</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Portfolio</h5>
                    <h2 class="fw-bold text-warning">25</h2>
                    <p class="text-muted mb-0">Projects</p>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Messages</h5>
                    <h2 class="fw-bold text-danger">5</h2>
                    <p class="text-muted mb-0">Unread Messages</p>
                </div>
            </div>
        </div>

    </div>

    <div class="row mt-5">

        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Recent Activities</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">

                        <li class="list-group-item">
                            New service added.
                        </li>

                        <li class="list-group-item">
                            Team member updated.
                        </li>

                        <li class="list-group-item">
                            Portfolio item created.
                        </li>

                        <li class="list-group-item">
                            Contact message received.
                        </li>

                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body d-grid gap-2">

                    <a asp-controller="Service"
                       asp-action="Create"
                       class="btn btn-primary">
                        Add Service
                    </a>

                    <a asp-controller="Team"
                       asp-action="Create"
                       class="btn btn-success">
                        Add Team Member
                    </a>

                    <a asp-controller="Portfolio"
                       asp-action="Create"
                       class="btn btn-warning">
                        Add Portfolio
                    </a>

                </div>
            </div>
        </div>

    </div>

</div>