@using System.IO
@using solution.Helpers
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env
<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="utf-8">

	<title>Solution Responsive Web Template</title>
	<!--

	Template 2081 Solution

	http://www.tooplate.com/view/2081-solution

	-->
	<meta http-equiv="X-UA-Compatible" content="IE=Edge">
	<meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<meta name="keywords" content="";
	<meta name="description" content="">

	<!-- animate -->
	<link rel="stylesheet" href="~/assets/css/animate.min.css">
	<!-- bootstrap -->
	<link rel="stylesheet" href="~/assets/css/bootstrap.min.css">
	<!-- magnific pop up -->
	<link rel="stylesheet" href="~/assets/css/magnific-popup.css">
	<!-- font-awesome -->
	<link rel="stylesheet" href="~/assets/css/font-awesome.min.css">
	<!-- google font -->
	<link href='http://fonts.googleapis.com/css?family=Raleway:400,300,700,800' rel='stylesheet' type='text/css'>
	<!-- custom -->
	<link rel="stylesheet" href="~/assets/css/style.css">

</head>
<body data-spy="scroll" data-offset="50" data-target=".navbar-collapse">

	<!-- start navigation -->
	<div class="navbar navbar-fixed-top navbar-default" role="navigation">
		<div class="container">
			<div class="navbar-header">
				<button class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse">
					<span class="icon icon-bar"></span>
					<span class="icon icon-bar"></span>
					<span class="icon icon-bar"></span>
				</button>
				@{
					var webLogoPath = System.IO.Path.Combine(Env.WebRootPath ?? string.Empty, "assets", "images", "logo.png");
					var logoExists = System.IO.File.Exists(webLogoPath);
				}
				<a href="/" class="navbar-brand">@if (logoExists) { <img src="~/assets/images/logo.png" class="img-responsive" alt="logo" /> } else { <span>Solution</span> }</a>
			</div>
			<div class="collapse navbar-collapse">
				<ul class="nav navbar-nav navbar-right">
					<li><a href="#home" class="smoothScroll">HOME</a></li>
					<li><a href="#service" class="smoothScroll">SERVICE</a></li>
					<li><a href="#about" class="smoothScroll">ABOUT</a></li>
					<li><a href="#team" class="smoothScroll">TEAM</a></li>
					<li><a href="#pricing" class="smoothScroll">PRICING</a></li>
					<li><a href="#portfolio" class="smoothScroll">PORTFOLIO</a></li>
					<li><a href="#contact" class="smoothScroll">CONTACT</a></li>

					@* Admin panel link for Admin role only *@
					@if (User?.Identity?.IsAuthenticated ?? false && User.IsInRole(RoleConstants.Admin))
					{
						<li><a href="/admin">Admin Panel</a></li>
					}

					@* Authentication links *@
					@if (User?.Identity?.IsAuthenticated ?? false)
					{
						<li class="navbar-text">@User.Identity.Name</li>
						<li>
							<form action="/logout" method="post" class="navbar-form" style="display:inline; margin:0;">
								@Html.AntiForgeryToken()
								<button type="submit" class="btn btn-link" style="padding:0;">Logout</button>
							</form>
						</li>
					}
					else
					{
						<li><a href="/login">Login</a></li>
						<li><a href="/register">Register</a></li>
					}
				</ul>
			</div>
		</div>
	</div>
	<!-- end navigation -->
        <main role="main" class="pb-3">
            @RenderBody()
        </main>

	<!-- start footer -->
	<footer>
		<div class="container">
			<div class="row">
				<div class="col-md-8 col-sm-7">
					<p>Copyright &copy; 2017 Solution Company</p>
					<small>Designed by <a rel="nofollow" href="http://www.tooplate.com" target="_parent">Tooplate</a></small>
				</div>
				<div class="col-md-4 col-sm-5">
					<ul class="social-icon">
						<li><a href="#" class="fa fa-facebook"></a></li>
						<li><a href="#" class="fa fa-twitter"></a></li>
						<li><a href="#" class="fa fa-instagram"></a></li>
						<li><a href="#" class="fa fa-pinterest"></a></li>
						<li><a href="#" class="fa fa-google"></a></li>
						<li><a href="#" class="fa fa-github"></a></li>
					</ul>
				</div>
			</div>
		</div>
	</footer>
	<!-- end footer -->
	<!-- jQuery -->
	<script src="~/assets/js/jquery.js"></script>
	<!-- bootstrap -->
	<script src="~/assets/js/bootstrap.min.js"></script>
	<!-- isotope -->
	<script src="~/assets/js/isotope.js"></script>
	<!-- images loaded -->
	<script src="~/assets/js/imagesloaded.min.js"></script>
	<!-- wow -->
	<script src="~/assets/js/wow.min.js"></script>
	<!-- smoothScroll -->
	<script src="~/assets/js/smoothscroll.js"></script>
	<!-- jquery flexslider -->
	<script src="~/assets/js/jquery.flexslider.js"></script>
	<!-- Magnific Pop up -->
	<script src="~/assets/js/jquery.magnific-popup.min.js"></script>
	<!-- custom -->
	<script src="~/assets/js/custom.js"></script>

	@RenderSection("Scripts", required: false)

</body>
</html>